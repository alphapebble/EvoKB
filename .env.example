# EvoKB Environment Variables

# Model settings
MODEL=ollama/llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# Gmail Connector (set via Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Notion Connector (get from notion.so/my-integrations)
NOTION_API_KEY=

# Slack Connector (get from api.slack.com)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Discord Connector (get from discord.com/developers)
DISCORD_BOT_TOKEN=

# Optional: OpenAI
OPENAI_API_KEY=
